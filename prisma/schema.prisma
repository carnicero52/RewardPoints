// Royalty QR - Multi-tenant Loyalty Platform Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  directUrl    = env("DIRECT_URL")
  relationMode = "prisma"
}

// =====================
// BUSINESS (Tenant/Negocio)
// =====================
model Business {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  brandColor  String   @default("#6366f1")
  description String?

  // Reward Configuration
  pointsPerFrequency  Int      @default(1) // Points to earn per X visits
  frequency          Int      @default(1) // Visits required to earn points (e.g., 1 point every X visits)
  pointsForReward    Int      @default(10) // Puntos necesarios para premio
  rewardDescription  String?  // Descripción del premio
  rewardImageUrl     String?  // URL de imagen del premio
  
  // Anti-cheat Configuration
  cooldownHours     Int      @default(24) // Horas entre check-ins (anti-trampa)
  maxDailyCheckIns  Int      @default(1)  // Máx check-ins por día

  // Contact
  email    String?
  phone    String?
  address  String?
  city     String?
  country  String   @default("México")

  // Notification Settings
  smtpHost     String?
  smtpPort     Int?
  smtpUser     String?
  smtpPassword String?
  smtpFrom     String?
  smtpEnabled  Boolean  @default(false)

  // Email notifications
  emailEnabled Boolean @default(false)
  emailFrom    String?

  // Telegram (Callmebot)
  telegramBotToken    String?
  telegramChatId      String?
  telegramEnabled     Boolean  @default(false)

  // Notification preferences
  notifyOnCheckin       Boolean @default(true)
  notifyOnReward        Boolean @default(true)
  notifyOnInactive      Boolean @default(false)
  customCheckinMessage  String?
  customRewardMessage   String?

  // Configuration
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  customers   Customer[]
  transactions Transaction[]
  staff       Staff[]
  rewards     Reward[]
  notifications Notification[]
  qRCodes       QRCode[]

  @@index([slug])
}

// =====================
// STAFF (Personal del negocio)
// =====================
model Staff {
  id           String   @id @default(cuid())
  businessId   String
  name         String
  email        String
  passwordHash String
  role         String   @default("employee") // admin, manager, employee
  active       Boolean  @default(true)
  lastLogin    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([email, businessId])
  @@index([businessId])
}

// =====================
// CUSTOMER (Cliente fidelizado)
// =====================
model Customer {
  id           String   @id @default(cuid())
  businessId   String
  name         String
  email        String?
  phone        String?
  telegram     String?
  callmebot    String?
  totalPoints  Int      @default(0)
  totalVisits  Int      @default(0)

  // For identification
  pin          String?  // PIN de 4-6 dígitos para check-in rápido
  
  // Anti-cheat tracking
  lastCheckIn     DateTime?  // Último check-in
  lastCheckInDate String?  // Fecha del último check-in (para daily limit)
  checkInCountToday Int  @default(0) // Check-ins hoy

  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  rewards      CustomerReward[]

  @@unique([email, businessId])
  @@index([businessId])
  @@index([phone, businessId])
}

// =====================
// TRANSACTION (Compra/Visita)
// =====================
model Transaction {
  id          String   @id @default(cuid())
  customerId  String
  businessId  String
  amount      Float?
  points      Int      @default(1)
  notes       String?

  // Status
  status      String   @default("completed") // pending, completed, cancelled

  // Staff who validated
  validatedBy String?

  createdAt   DateTime @default(now())

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([businessId])
  @@index([createdAt])
}

// =====================
// REWARD (Premio configurable)
// =====================
model Reward {
  id           String   @id @default(cuid())
  businessId   String
  name         String
  description  String?
  pointsNeeded Int
  imageUrl     String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business        Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerRewards CustomerReward[]

  @@index([businessId])
}

// =====================
// CUSTOMER REWARD (Premio canjeado)
// =====================
model CustomerReward {
  id          String   @id @default(cuid())
  customerId  String
  rewardId    String
  redeemedAt  DateTime @default(now())
  status      String   @default("pending") // pending, delivered, expired

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  reward      Reward   @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([rewardId])
}

// =====================
// NOTIFICATION (Notificaciones)
// =====================
model Notification {
  id          String   @id @default(cuid())
  businessId  String
  customerId  String?
  type        String   // marketing, collection, reminder, system
  title       String
  message     String

  // Channel
  channel     String   @default("email") // email, telegram, sms, whatsapp

  // Status
  status      String   @default("pending") // pending, sent, failed
  sentAt      DateTime?
  scheduledAt DateTime?

  createdAt   DateTime @default(now())

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([customerId])
  @@index([status])
}

// =====================
// QR CODE (Código QR del negocio)
// =====================
model QRCode {
  id        String   @id @default(cuid())
  businessId String
  code      String   @unique
  expiresAt DateTime
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([code])
}